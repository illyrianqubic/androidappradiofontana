{
  "expo": {
    "name": "RTV Fontana",
    "slug": "androidappradiofontana",
    "version": "1.0.0",
    "scheme": "radiofontana",
    "orientation": "portrait",
    "icon": "./assets/images/darklogortvfontana.png",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "newArchEnabled": true,
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/afce0836-d64a-4c6e-9f33-7a0a4d0ae957"
    },
    "splash": {
      "image": "./assets/images/darklogortvfontana.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.radiofontana.app",
      "icon": "./assets/images/darklogortvfontana.png",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationCategoryType": "public.app-category.music"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground-dark.png",
        "backgroundColor": "#0B1220"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.radiofontana.app",
      "assets": [
        "assets/adi-registration.properties"
      ],
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/with-adi-registration-asset",
      "./plugins/with-dynamic-app-icon",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/darklogortvfontana.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#0B1220"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf",
            "./node_modules/@expo-google-fonts/inter/400Regular/Inter_400Regular.ttf",
            "./node_modules/@expo-google-fonts/inter/500Medium/Inter_500Medium.ttf",
            "./node_modules/@expo-google-fonts/inter/700Bold/Inter_700Bold.ttf",
            "./node_modules/@expo-google-fonts/merriweather/400Regular/Merriweather_400Regular.ttf",
            "./node_modules/@expo-google-fonts/merriweather/700Bold/Merriweather_700Bold.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "afce0836-d64a-4c6e-9f33-7a0a4d0ae957"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}

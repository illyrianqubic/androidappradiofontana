{
  "expo": {
    "name": "RTV Fontana",
    "slug": "rtv-fontana",
    "version": "1.0.2",
    "scheme": "rtvfontana",
    "orientation": "portrait",
    "icon": "./assets/images/icon-ios-new.png",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rtvfontana.android",
      "buildNumber": "1",
      "icon": {
        "light": "./assets/images/icon-ios-light-new.png",
        "dark": "./assets/images/icon-ios-new.png"
      },
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationCategoryType": "public.app-category.music",
        "NSMicrophoneUsageDescription": "Kjo app nuk përdor mikrofonin.",
        "UIRequiresFullScreen": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground-dark.png",
        "backgroundColor": "#0B1220"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.rtvfontana.android",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/with-adi-registration-asset",
      "./plugins/with-dynamic-app-icon",
      "expo-router",
      "@sentry/react-native/expo",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/darklogortvfontana.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#0B1220"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf"
          ]
        }
      ],
      "expo-asset",
      "expo-audio",
      "expo-image",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f147c876-71ac-44b2-87c6-f386f5db4063"
      }
    },
    "owner": "frescoid1s-team"
  }
}

    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-persist-client": "^5.90.5",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-linear-gradient": "~15.0.7",
